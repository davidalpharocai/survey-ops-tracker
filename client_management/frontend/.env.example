# Local development only — never commit a real .env
DEV_USER_EMAIL=you@alpharoc.ai
ALLOWED_DOMAIN=alpharoc.ai

# HTTP Basic Auth (production gate). When BOTH are set the browser
# prompts for credentials and DEV_USER_EMAIL/IAP are ignored. The
# username MUST be the @alpharoc.ai email used for backend attribution.
# Leave blank locally to use DEV_USER_EMAIL instead.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# FastAPI backend the app now calls for ALL data and writes.
BACKEND_URL=http://127.0.0.1:8000
# Must match the backend's INTERNAL_API_SECRET. Leave blank locally if
# the backend also has it blank; set a strong random value in prod.
BACKEND_SHARED_SECRET=

# PostgreSQL connection string — now ONLY used by the seed/migration
# scripts in scripts/ (the app no longer talks to Postgres directly;
# the backend owns the database and schema).
# Local dev: run Postgres yourself, e.g.
#   docker run -d --name ccdb -e POSTGRES_PASSWORD=dev -p 5432:5432 postgres:16
# Production (RDS): require TLS by appending ?sslmode=require
DATABASE_URL=postgresql://postgres:dev@localhost:5432/clientcredits?schema=public
