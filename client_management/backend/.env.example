# Local development only — never commit a real .env
ENV=development
ALLOWED_DOMAIN=alpharoc.ai

# Shared secret the Express frontend must send as X-Internal-Auth.
# Leave blank locally to disable the check; set a strong random value
# (e.g. `openssl rand -hex 32`) in production. Must match the
# frontend's BACKEND_SHARED_SECRET.
INTERNAL_API_SECRET=

# Same PostgreSQL instance the frontend uses. Local dev, e.g.:
#   docker run -d --name ccdb -e POSTGRES_PASSWORD=dev \
#     -e POSTGRES_DB=clientcredits -p 5432:5432 postgres:16
# Production (RDS): append ?ssl=require
DATABASE_URL=postgresql://postgres:dev@localhost:5432/clientcredits

# Cognito (production; leave blank locally to use the X-User-Email path).
# COGNITO_USER_POOL_ID and COGNITO_APP_CLIENT_ID enable JWT verification.
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_ALLOWED_GROUP=ccm-users
# Members of this nested group may reach the admin audit-log page.
COGNITO_ADMIN_GROUP=ccm-admins

# Athena audit-log query path (set by Terraform in the deployed stack).
# Leave blank locally — the admin endpoints then return an empty result.
ATHENA_DATABASE=
ATHENA_TABLE=
ATHENA_WORKGROUP=
AUDIT_S3_OUTPUT=
